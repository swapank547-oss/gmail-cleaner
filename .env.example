FLASK_SECRET_KEY=generate-a-random-key-here
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# The callback URL must match exactly what's configured in Google Cloud Console
# For local testing: http://localhost:5000/oauth2callback
# For production: https://yourdomain.com/oauth2callback
OAUTH_REDIRECT_URI=http://localhost:5000/oauth2callback
